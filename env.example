# ClaimTrace — Environment Variables
# Copy this to .env and fill in your keys
# For the Next.js app, also copy relevant vars to .env.local

# ── Gemini (get free key at aistudio.google.com) ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cognee Cloud (get from your Cognee Cloud console) ──
COGNEE_TENANT_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=your_cognee_api_key_here
